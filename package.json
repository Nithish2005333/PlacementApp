{
  "name": "placement-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nodemon",
    "start": "node server/index.js",
    "client:install": "cd client && npm ci || npm install",
    "client:dev": "cd client && npm run dev",
    "client:build": "cd client && npm run build",
    "client:preview": "cd client && npm run preview",
    "build": "npm run client:build",
    "postinstall": "npm run client:install && npm run client:build"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.2",
    "morgan": "^1.10.0",
    "path": "^0.12.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=18"
  }
}

